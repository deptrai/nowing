# Playwright E2E — Environment Variables
# Copy to .env.test and fill in values. Never commit .env.test.

# --- App URLs ---
BASE_URL=http://localhost:4998
API_URL=http://localhost:8000

# --- Default test user (maps to auth-provider.ts) ---
TEST_USER_EMAIL=test@nowing.test
TEST_USER_PASSWORD=Admin@Nowing1

# --- Multi-user testing ---
# TEST_ADMIN_EMAIL=admin@nowing.ai
# TEST_ADMIN_PASSWORD=Admin@Nowing1

# --- Auth debug ---
# DEBUG_AUTH=true

# --- CI overrides (set in CI secrets, not here) ---
# CI=true
