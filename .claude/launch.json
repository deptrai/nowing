{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Nowing Frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "nowing_web",
      "port": 3999,
      "autoPort": false
    },
    {
      "name": "Nowing Backend",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["app.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "nowing_backend",
      "port": 8000
    },
    {
      "name": "Nowing Full Stack (Docker Dev)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "docker/docker-compose.dev.yml", "up", "--build"],
      "cwd": ".",
      "port": 3000
    }
  ]
}
